# Copy to .env and fill in. .env is gitignored.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Fast default for launch. Override per task if needed:
# - Haiku: fastest/cheapest
# - Sonnet: stronger middle ground
# - Opus: slowest/heaviest
RABBIT_HOLE_MODEL=claude-haiku-4-5
RABBIT_HOLE_CLUSTER_MODEL=claude-haiku-4-5
RABBIT_HOLE_ASK_MODEL=claude-haiku-4-5
RABBIT_HOLE_BRIEF_MODEL=claude-haiku-4-5

# Allowed browser origin(s) for CORS — comma-separated. In production set this
# to the deployed web origin (NOT localhost) or the browser will block the app.
WEB_ORIGIN=http://localhost:3000

# Local-only escape hatch: authenticate every request as one shared "dev-user"
# when no Supabase auth is configured. Leave UNSET in production — without the
# Supabase vars below the API otherwise fails closed (503) instead of fail-open.
RABBIT_HOLE_DEV_USER=1

# Simple per-process safety limits. Tune these in Railway before opening access.
RATE_LIMIT_EVENTS_PER_MIN=180
RATE_LIMIT_CLUSTER_PER_HOUR=8
RATE_LIMIT_AI_PER_HOUR=20
RATE_LIMIT_READS_PER_MIN=120

# Optional now, required for real persistent accounts.
# Use the Supabase "Connection string" URI.
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Required when you want real authenticated users instead of the local dev user.
# Supabase Dashboard -> Project Settings -> API -> JWT Secret.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Alternative auth verification path if you do not set SUPABASE_JWT_SECRET.
# Supabase Dashboard -> Project Settings -> API.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
