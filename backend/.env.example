# Copy to .env and fill in. .env is gitignored.
ANTHROPIC_API_KEY=sk-ant-api03-...
RABBIT_HOLE_MODEL=claude-opus-4-8
WEB_ORIGIN=http://localhost:3000

# Simple per-process safety limits. Tune these in Railway before opening access.
RATE_LIMIT_EVENTS_PER_MIN=240
RATE_LIMIT_CLUSTER_PER_HOUR=20
RATE_LIMIT_AI_PER_HOUR=60
RATE_LIMIT_READS_PER_MIN=120

# Optional now, required for real persistent accounts.
# Use the Supabase "Connection string" URI.
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Required when you want real authenticated users instead of the local dev user.
# Supabase Dashboard -> Project Settings -> API -> JWT Secret.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
