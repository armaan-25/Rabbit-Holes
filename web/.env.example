# Copy to .env.local and fill in. .env.local is gitignored.
# All NEXT_PUBLIC_* values are inlined into the client bundle at BUILD time,
# so they must be set in the deploy environment before `next build`.

# The FastAPI backend. Defaults to http://localhost:8000 if unset — which means
# a production build with this unset will call localhost and every Ask /
# clustering / stats request will fail. Set it to the deployed backend origin.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Supabase project (publishable anon key — safe to ship in the client bundle).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
