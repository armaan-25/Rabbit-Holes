{
  "manifest_version": 3,
  "name": "Rabbit Holes",
  "description": "Turns your browsing into structured investigations.",
  "version": "0.1.0",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": [
    "tabs",
    "history",
    "storage",
    "webNavigation",
    "alarms",
    "idle"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://userabbitholes.com/*",
        "http://localhost:3000/*"
      ],
      "js": [
        "stats-bridge.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Rabbit Holes",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "externally_connectable": {
    "matches": [
      "https://userabbitholes.com/*"
    ]
  }
}
